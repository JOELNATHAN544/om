# =============================================================================
# Backstage Secrets Configuration Template
# =============================================================================
# Copy this file to: configs/secrets-templates/backstage-secrets.env
# Fill in your actual values (DO NOT commit the .env file!)
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------
# Create a GitHub Personal Access Token with repo, read:org, read:user scopes
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-org-name
GITHUB_REPO=your-repo-name

# Git repo and revision (branch/tag/commit) ArgoCD should deploy from
OM_GIT_REPO_URL=https://github.com/your-org-name/your-repo-name.git
OM_GIT_REVISION=dep/20-deploy-backstage-developer-portal

# -----------------------------------------------------------------------------
# Google OAuth (OIDC Authentication)
# -----------------------------------------------------------------------------
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://portal.backstage.com/api/auth/google/handler/frame
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# -----------------------------------------------------------------------------
# AWS Credentials (for TechDocs S3 storage)
# -----------------------------------------------------------------------------
# Create IAM user with S3 access for TechDocs bucket
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
TECHDOCS_BUCKET=your-techdocs-bucket-name

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# Database password for Backstage catalog
POSTGRES_PASSWORD=change-me-in-production

# -----------------------------------------------------------------------------
# ArgoCD Integration (Optional - configure after ArgoCD is set up)
# -----------------------------------------------------------------------------
ARGOCD_USERNAME=admin
ARGOCD_PASSWORD=password

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
# Domain where Backstage will be accessible
BACKSTAGE_DOMAIN=portal.backstage.com
ARGOCD_DOMAIN=argocd.backstage.com
